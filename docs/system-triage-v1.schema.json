{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/system-triage-v1.schema.json",
  "title": "System Triage V1",
  "$comment": "This schema validates local structure only. Cross-field invariants such as score derivation, status consistency, ref resolution, uniqueness-by-id, deterministic ordering, source id/tool/scope mapping, and finding type/category/id consistency remain producer-side validation requirements.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "kind",
    "host",
    "captured_at",
    "window_minutes",
    "summary",
    "findings",
    "actions",
    "sources"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "kind": {
      "const": "system_triage"
    },
    "host": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64
    },
    "captured_at": {
      "type": "string",
      "format": "date-time"
    },
    "window_minutes": {
      "const": 60
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "score",
        "headline"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "ok",
            "info",
            "warning",
            "critical"
          ]
        },
        "score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "headline": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        }
      }
    },
    "findings": {
      "type": "array",
      "maxItems": 10,
      "items": {
        "$ref": "#/$defs/finding"
      }
    },
    "actions": {
      "type": "array",
      "maxItems": 5,
      "items": {
        "$ref": "#/$defs/action"
      }
    },
    "sources": {
      "type": "array",
      "maxItems": 12,
      "items": {
        "$ref": "#/$defs/source"
      }
    }
  },
  "$defs": {
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "type",
        "severity",
        "category",
        "title",
        "reason",
        "evidence",
        "confidence",
        "source_refs"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "type": {
          "type": "string",
          "enum": [
            "high_cpu",
            "high_memory",
            "low_disk",
            "unstable_service",
            "repeated_system_errors",
            "abnormal_uptime_signal"
          ]
        },
        "severity": {
          "type": "string",
          "enum": [
            "info",
            "warning",
            "critical"
          ]
        },
        "category": {
          "type": "string",
          "enum": [
            "cpu",
            "memory",
            "disk",
            "service",
            "eventlog",
            "uptime"
          ]
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100
        },
        "reason": {
          "type": "string",
          "minLength": 1,
          "maxLength": 220
        },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "maxItems": 3,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 120
          }
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "source_refs": {
          "type": "array",
          "minItems": 1,
          "maxItems": 3,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 40
          }
        }
      }
    },
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "priority",
        "kind",
        "target",
        "reason_code",
        "reason",
        "related_finding_ids"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "priority": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        },
        "kind": {
          "type": "string",
          "enum": [
            "inspect",
            "confirm",
            "ignore",
            "monitor",
            "escalate"
          ]
        },
        "target": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "reason_code": {
          "type": "string",
          "enum": [
            "cpu_consumers_review",
            "memory_consumers_review",
            "volume_consumers_review",
            "service_instability_confirmation",
            "service_instability_escalation",
            "event_source_review",
            "uptime_monitoring"
          ]
        },
        "reason": {
          "type": "string",
          "minLength": 1,
          "maxLength": 160
        },
        "related_finding_ids": {
          "type": "array",
          "minItems": 1,
          "maxItems": 3,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80
          }
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "tool",
        "captured_at",
        "scope"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 40
        },
        "tool": {
          "type": "string",
          "enum": [
            "Get-SystemSummary",
            "Get-TopProcesses",
            "Get-ServiceStatus",
            "Get-EventLogEntries",
            "Get-StorageStatus"
          ]
        },
        "captured_at": {
          "type": "string",
          "format": "date-time"
        },
        "scope": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        }
      }
    }
  }
}
